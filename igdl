const API = "https://api-wh.sssinstagram.com/api/convert";

const INSTAGRAM_URL =
  "https://www.instagram.com/reel/DYSDe0qJTiI/?igsh=MXFyZnIxNWw1cXR0bw==";

function isInstagramUrl(url) {
  return /^https?:\/\/(www\.)?instagram\.com\/(reel|p|tv)\//i.test(url);
}

function detectType(url = "") {
  const clean = url.split("?")[0].toLowerCase();

  if (clean.endsWith(".mp4")) return "video";
  if (clean.endsWith(".jpg")) return "image";
  if (clean.endsWith(".jpeg")) return "image";
  if (clean.endsWith(".png")) return "image";
  if (clean.endsWith(".webp")) return "image";

  return "media";
}

function getDirectUrl(url = "") {
  try {
    const parsed = new URL(url);
    const uri = parsed.searchParams.get("uri");

    if (uri && uri.startsWith("http")) {
      return uri;
    }

    return url;
  } catch {
    return url;
  }
}

function cleanResult(data, input, code = 200) {
  const items = Array.isArray(data?.url) ? data.url : [];

  const results = items
    .map((item) => {
      const rawUrl = item?.url;
      if (!rawUrl) return null;

      const directUrl = getDirectUrl(rawUrl);

      return {
        type: item.type === "mp4" ? "video" : detectType(directUrl),
        url: directUrl,
      };
    })
    .filter(Boolean);

  return {
    status: results.length > 0,
    code,
    input,
    total: results.length,
    results,
    ...(results.length === 0
      ? {
          error: "Media tidak ditemukan",
        }
      : {}),
  };
}

async function requestJsonMode(url) {
  const response = await fetch(API, {
    method: "POST",
    headers: {
      accept: "application/json, text/plain, */*",
      "content-type": "application/json",
      origin: "https://sssinstagram.com",
      referer: "https://sssinstagram.com/",
      "user-agent":
        "Mozilla/5.0 (Linux; Android 10; Mobile) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Mobile Safari/537.36",
    },
    body: JSON.stringify({ url }),
  });

  const text = await response.text();

  return {
    code: response.status,
    text,
  };
}

async function requestFormMode(url) {
  const body = new URLSearchParams();
  body.append("url", url);

  const response = await fetch(API, {
    method: "POST",
    headers: {
      accept: "application/json, text/plain, */*",
      "content-type": "application/x-www-form-urlencoded; charset=UTF-8",
      origin: "https://sssinstagram.com",
      referer: "https://sssinstagram.com/",
      "user-agent":
        "Mozilla/5.0 (Linux; Android 10; Mobile) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Mobile Safari/537.36",
    },
    body: body.toString(),
  });

  const text = await response.text();

  return {
    code: response.status,
    text,
  };
}

async function parseResponse(text) {
  try {
    return JSON.parse(text);
  } catch {
    return null;
  }
}

async function igdl(url) {
  if (!url) {
    return {
      status: false,
      code: 400,
      input: url,
      total: 0,
      results: [],
      error: "Link Instagram kosong",
    };
  }

  if (!isInstagramUrl(url)) {
    return {
      status: false,
      code: 400,
      input: url,
      total: 0,
      results: [],
      error: "Link harus Instagram reel/post/tv",
    };
  }

  try {
    let req = await requestJsonMode(url);
    let json = await parseResponse(req.text);
    let result = json ? cleanResult(json, url, req.code) : null;

    if (result?.status) {
      return result;
    }

    req = await requestFormMode(url);
    json = await parseResponse(req.text);
    result = json ? cleanResult(json, url, req.code) : null;

    if (result) {
      return result;
    }

    return {
      status: false,
      code: req.code,
      input: url,
      total: 0,
      results: [],
      error: "Response bukan JSON valid",
      raw: req.text.slice(0, 500),
    };
  } catch (error) {
    return {
      status: false,
      code: 500,
      input: url,
      total: 0,
      results: [],
      error: error.message,
    };
  }
}

igdl(INSTAGRAM_URL)
  .then((result) => {
    console.log(JSON.stringify(result, null, 2));
  })
  .catch((error) => {
    console.log(
      JSON.stringify(
        {
          status: false,
          code: 500,
          input: INSTAGRAM_URL,
          total: 0,
          results: [],
          error: error.message,
        },
        null,
        2
      )
    );

    process.exit(1);
  });
